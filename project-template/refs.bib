// refs.bib
// 参考文献ファイル
//
// BibTeX 形式で参考文献を記述してください。
// 使い方:
//   1. このファイルに文献情報を追加する
//   2. main.typ の末尾に #bibliography("refs.bib") を追加する
//   3. 本文中で @key で引用する
//
// 例:
// @article{einstein1905,
//   author = "Albert Einstein",
//   title  = "On the electrodynamics of moving bodies",
//   journal = "Annalen der Physik",
//   volume = "322",
//   number = "10",
//   pages  = "891--921",
//   year   = "1905",
// }
